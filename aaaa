local Team = Tabs.Auto:AddLeftGroupbox("Team")

local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TextChatService = game:GetService("TextChatService")

local player = Players.LocalPlayer
local guiPath = player.PlayerGui.Menu.Main.Menus.Pickups.Content.List
local remote = ReplicatedStorage:WaitForChild("PickupsManager")

local TeamChoice = "Blue"
local RoleChoice = "Oppo"
local SpeakEnabled = false
local AutoJoinLoop
local HasAnnounced = false

Team:AddDropdown("SelectTeam", {
    Values = {"Blue", "Red"},
    Default = 1,
    Multi = false,
    Text = "Select Team",
    Callback = function(Value)
        TeamChoice = Value
    end
})

Team:AddDropdown("SelectRole", {
    Values = {"Oppo", "Mid", "Out", "Setter", "Lib", "Pipe"},
    Default = 1,
    Multi = false,
    Text = "Select Position",
    Callback = function(Value)
        RoleChoice = Value
    end
})

Team:AddToggle("SpeakPosition", {
    Text = "Say Position",
    Default = false,
    Callback = function(Value)
        SpeakEnabled = Value
    end
})

Team:AddToggle("AutoJoinTeam", {
    Text = "Auto Join",
    Default = false,
    Callback = function(Value)
        if Value then
            HasAnnounced = false

            if AutoJoinLoop then
                AutoJoinLoop:Disconnect()
            end

            AutoJoinLoop = RunService.Heartbeat:Connect(function()
                if HasAnnounced then return end

                for _, frame in pairs(guiPath:GetChildren()) do
                    if frame:IsA("Frame")
                        and frame:FindFirstChild("TextLabel")
                        and frame:FindFirstChild("Team")
                        and frame:FindFirstChild("PlayingPosition") then

                        if frame.TextLabel.Text == "OPEN"
                            and frame.Team.Value == TeamChoice then

                            local pos = frame.PlayingPosition.Value

                            HasAnnounced = true

                            local args = { [1] = TeamChoice, [2] = pos }
                            remote:FireServer(unpack(args))

                            if SpeakEnabled then
                                task.wait(0.1)
                                local prefix = (TeamChoice == "Blue") and "B" or "R"
                                local msg = prefix .. " " .. RoleChoice

                                local chat = TextChatService:FindFirstChild("TextChannels")
                                if chat and chat:FindFirstChild("RBXGeneral") then
                                    chat.RBXGeneral:SendAsync(msg)
                                end
                            end

                            if Toggles.AutoJoinTeam then
                                Toggles.AutoJoinTeam:SetValue(false)
                            end
                            if AutoJoinLoop then
                                AutoJoinLoop:Disconnect()
                                AutoJoinLoop = nil
                            end

                            break
                        end
                    end
                end
            end)
        else
            if AutoJoinLoop then
                AutoJoinLoop:Disconnect()
                AutoJoinLoop = nil
            end
        end
    end
})
