local transparency = 0.5
local hitboxConnection = nil
local childAddedConnection = nil
local playerMonitors = {}

Legit:AddToggle(
    "hitboxVisualizer",
    {
        Text = "Show Block Hitboxes",
        Default = false,
        Callback = function(enabled)
            local function isSizeSmall(size)
                return size.X < 1 or size.Y < 1 or size.Z < 1
            end

            local function monitorPlayer(player)
                local function updateHitboxes()
                    local blocking = player:FindFirstChild("BLOCKING")
                    
                    local blockHitbox = player:FindFirstChild("BlockHitbox")
                    if blockHitbox then
                        if blocking then
                            blockHitbox.Transparency = transparency
                            
                            if isSizeSmall(blockHitbox.Size) then
                                blockHitbox.Size = Vector3.new(5, 7, 2)
                            end
                        else
                            blockHitbox.Transparency = 1
                        end
                    end
                end
                
                updateHitboxes()
                
                local addedConn = player.ChildAdded:Connect(function(child)
                    if child.Name == "BLOCKING" then
                        updateHitboxes()
                    end
                end)
                
                local removedConn = player.ChildRemoved:Connect(function(child)
                    if child.Name == "BLOCKING" then
                        updateHitboxes()
                    end
                end)
                
                table.insert(playerMonitors, addedConn)
                table.insert(playerMonitors, removedConn)
            end

            if enabled then
                for _, obj in pairs(workspace:GetChildren()) do
                    if obj:IsA("Model") then
                        monitorPlayer(obj)
                    end
                end
                
                childAddedConnection = workspace.ChildAdded:Connect(function(child)
                    if child:IsA("Model") then
                        monitorPlayer(child)
                    end
                end)
                
                hitboxConnection = game:GetService("RunService").Heartbeat:Connect(function()
                    for _, obj in pairs(workspace:GetChildren()) do
                        if obj:IsA("Model") then
                            local blocking = obj:FindFirstChild("BLOCKING")
                            
                            local blockHitbox = obj:FindFirstChild("BlockHitbox")
                            if blockHitbox then
                                if blocking then
                                    blockHitbox.Transparency = transparency
                                    
                                    if isSizeSmall(blockHitbox.Size) then
                                        blockHitbox.Size = Vector3.new(5, 7, 2)
                                    end
                                else
                                    blockHitbox.Transparency = 1
                                end
                            end
                        end
                    end
                end)
            else
                if hitboxConnection then
                    hitboxConnection:Disconnect()
                    hitboxConnection = nil
                end
                
                if childAddedConnection then
                    childAddedConnection:Disconnect()
                    childAddedConnection = nil
                end
                
                for _, conn in pairs(playerMonitors) do
                    conn:Disconnect()
                end
                playerMonitors = {}
            end
        end
    }
)

