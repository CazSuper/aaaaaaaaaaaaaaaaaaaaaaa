-- Criar billboard
local function criarBillboard(player)
    local playerName = player.Name
    
    if billboards[playerName] then return end

    local character = player.Character or player.CharacterAdded:Wait()
    local head = character:FindFirstChild("Head")
    if not head then return end

    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(4, 0, 2, 0)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.MaxDistance = 100
    billboard.AlwaysOnTop = true
    billboard.Parent = head

    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.TextScaled = true
    textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    textLabel.Text = "..."
    textLabel.Parent = billboard

    billboards[playerName] = billboard

    -- Atualização leve (sem while pesado infinito)
    local function atualizarTexto()
        local char = player.Character
        if not char then return end

        local power = char:FindFirstChild("Power")
        if power and power:IsA("NumberValue") then
            textLabel.Text = tostring(power.Value)
        else
            textLabel.Text = "N/A"
        end
    end

    atualizarTexto()

    -- Atualiza quando Power mudar
    local char = player.Character
    if char then
        local power = char:FindFirstChild("Power")
        if power then
            power:GetPropertyChangedSignal("Value"):Connect(atualizarTexto)
        end
    end

    -- Atualiza quando respawnar
    player.CharacterAdded:Connect(function(newChar)
        local newHead = newChar:WaitForChild("Head", 5)
        if newHead then
            billboard.Parent = newHead
        end

        local power = newChar:FindFirstChild("Power")
        if power then
            power:GetPropertyChangedSignal("Value"):Connect(atualizarTexto)
        end

        atualizarTexto()
    end)
end

-- Remover
local function removerBillboard(playerName)
    if billboards[playerName] then
        billboards[playerName]:Destroy()
        billboards[playerName] = nil
    end
end

-- Atualizar tudo
function atualizarBillboards()
    -- limpa
    for name in pairs(billboards) do
        removerBillboard(name)
    end

    if showAllPlayers then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= localPlayer then
                criarBillboard(player)
            end
        end

    elseif showSelectedOnly then
        for playerName, isSelected in pairs(selectedPlayers) do
            if isSelected then
                local player = Players:FindFirstChild(playerName)
                if player then
                    criarBillboard(player)
                end
            end
        end
    end
end

-- Atualizar dropdown quando player entra/sai
local function atualizarDropdown()
    if dropdown and dropdown.SetValues then
        dropdown:SetValues(getPlayersList())
    end
end

Players.PlayerAdded:Connect(function()
    task.wait(0.5)
    atualizarDropdown()
    atualizarBillboards()
end)

Players.PlayerRemoving:Connect(function(player)
    removerBillboard(player.Name)
    atualizarDropdown()
end)


