local originalSpeed = nil

Movement:AddToggle(
    "ToggleWalkspeed",
    {
        Text = "Walkspeed",
        Default = false,
        Callback = function(isEnabled)
            local player = game:GetService("Players").LocalPlayer

            local function InitializeWalkspeedController()
                local character = player.Character
                if not character then
                    return
                end

                local humanoid = character:FindFirstChildWhichIsA("Humanoid")
                if not humanoid then
                    return
                end

                if not originalSpeed then
                    originalSpeed = humanoid.WalkSpeed
                end

                if heartbeatConn then
                    heartbeatConn:Disconnect()
                end
                if propertyConn then
                    propertyConn:Disconnect()
                end

                heartbeatConn =
                    game:GetService("RunService").Heartbeat:Connect(
                    function()
                        if
                            player.Character and player.Character:FindFirstChildWhichIsA("Humanoid") and
                                getgenv().Enabled
                         then
                            player.Character:FindFirstChildWhichIsA("Humanoid").WalkSpeed = getgenv().Speed
                        end
                    end
                )

                propertyConn =
                    humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(
                    function()
                        if getgenv().Enabled then
                            humanoid.WalkSpeed = getgenv().Speed
                        end
                    end
                )
            end

            if isEnabled then
                getgenv().Enabled = true
                InitializeWalkspeedController()
                charAddedConn =
                    player.CharacterAdded:Connect(
                    function(char)
                        char:WaitForChild("Humanoid")
                        task.wait(0.1)
                        InitializeWalkspeedController()
                    end
                )
            else
                getgenv().Enabled = false
                if heartbeatConn then
                    heartbeatConn:Disconnect()
                end
                if propertyConn then
                    propertyConn:Disconnect()
                end
                if charAddedConn then
                    charAddedConn:Disconnect()
                end

                local humanoid = player.Character and player.Character:FindFirstChildWhichIsA("Humanoid")
                if humanoid and originalSpeed then
                    humanoid.WalkSpeed = originalSpeed
                end
            end
        end
    }
)

